# Public production URL used in verification, reset, and dashboard email links.
NEXT_PUBLIC_SITE_URL=https://shotokan-karate-regina.vercel.app
APP_BASE_URL=https://shotokan-karate-regina.vercel.app

# Required in production: Upstash/Vercel KV-compatible REST database.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Required for administrator PDF and featured-image uploads.
# Connect a private Vercel Blob store to the project to generate this value.
BLOB_READ_WRITE_TOKEN=

# Email delivery (Resend) and administrator notifications.
RESEND_API_KEY=
RESEND_FROM="SHOTOKAN Karate Regina <registration@your-verified-domain.ca>"
REGISTRATION_EMAIL=reza.abbasi.wkf@gmail.com
# Generic aliases are also supported:
# EMAIL_API_KEY=
# EMAIL_FROM_ADDRESS="SHOTOKAN Karate Regina <registration@your-verified-domain.ca>"
ADMIN_NOTIFICATION_EMAIL=reza.abbasi.wkf@gmail.com

# Comma-separated emails that receive the administrator role after verification.
ADMIN_EMAILS=reza.abbasi.wkf@gmail.com

# Optional development-only database path. Never use local files on Vercel.
# PORTAL_DATABASE_FILE=portal-development.json
